{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/voice-match-score", "destination": "/api/persona-signal" },
    { "source": "/api/admin/trigger-digest", "destination": "/api/intelligence?action=trigger-digest" },
    { "source": "/api/weekly-digest-cron", "destination": "/api/intelligence?action=weekly-digest-cron" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    { "path": "/api/weekly-digest-cron", "schedule": "0 13 * * 1" }
  ]
}
